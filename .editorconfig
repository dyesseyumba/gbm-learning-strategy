# EditorConfig helps maintain consistent coding styles for multiple developers
# working on the same project across various editors and IDEs.
# editorconfig.org

root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# R files
[*.{R,r,Rmd,rmd}]
indent_style = space
indent_size = 2
max_line_length = 80

# Jupyter Notebook files (JSON format)
[*.ipynb]
indent_style = space
indent_size = 2
max_line_length = 100

# Python files (often used with Jupyter)
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off
